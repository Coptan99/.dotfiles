#! /bin/sh

chosen=$(printf "яАС  Power Off\nяАЮ  Restart\nяЖЖ  Suspend\nяЛЬ  Hibernate\nябВ  Log Out\nяАг  Lock" | rofi -dmenu -i -theme-str '@import "power.rasi"')

case "$chosen" in
	"яАС  Power Off") doas poweroff ;;
	"яАЮ  Restart") doas reboot ;;
	"яЖЖ  Suspend") doas zzz ;;
	"яЛЬ  Hibernate") doas zzz -H ;;
	"ябВ  Log Out") killall i3 ;;
	"яАг  Lock") slock ;;
	*) exit 1 ;;
esac
