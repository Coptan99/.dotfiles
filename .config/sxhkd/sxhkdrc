super + Return
    $TERMINAL

super + v
    $TERMINAL -e $EDITOR

super + w
    $BROWSER

super + d
    dmenu_run

XF86MonBrightnessUp
    brillo -A 2

XF86MonBrightnessDown
    brillo -U 2

XF86Audio{Raise,Lower}Volume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%{+,-}; kill -44 $(pidof dwmblocks)

XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle; kill -44 $(pidof dwmblocks)

super + {equal, minus, BackSpace}
    volume {up, down, toggle}

XF86Calculator
    xcalc

Print
    $HOME/.local/bin/screenshot copyfull

super + Print
    $HOME/.local/bin/screenshot copy

shift + Print
    $HOME/.local/bin/screenshot window

ctrl + Print
    $HOME/.local/bin/screenshot

super + m
    $HOME/.local/bin/mount.sh

super + shift + BackSpace
    $HOME/.local/bin/exit.sh

super + r
    $TERMINAL -e nnn -Rr

super + t
    $TERMINAL -e gotop
