alt + Return
    $TERMINAL

alt + w
    $BROWSER

XF86MonBrightness{Up,Down}
    brillo -q -{A, U} 2

XF86Audio{Raise,Lower}Volume
    pactl set-sink-volume @DEFAULT_SINK@ {+, -}5%

XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle

XF86Calculator
    xcalc

Print
    $HOME/.local/bin/screenshot

alt + Print
    $HOME/.local/bin/screenshot copyfull

shift + Print
    $HOME/.local/bin/screenshot copy

alt + shift + Print
    $HOME/.local/bin/screenshot window

alt + m
    $HOME/.local/bin/mount.sh

alt + shift + BackSpace
    $HOME/.local/bin/powermenu

alt + n
    alacritty -e lf

alt + t
    alacritty -e gotop
