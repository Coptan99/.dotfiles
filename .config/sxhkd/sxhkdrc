super + Return
    $TERMINAL

super + v
    virt-manager

super + d
    dmenu_run

super + w
    $BROWSER

super + {equal, minus, BackSpace, plus}
    $HOME/script/volume.sh {up, down, toggle, togglemic}

super + shift + BackSpace
    $HOME/script/exit.sh

super + m
    $HOME/script/mount.sh

super + f
    $TERMINAL -e nnn -Rr

Print
    $HOME/script/screenshot

super + n
    $TERMINAL -e ncmpcpp

super + N
    $TERMINAL -e nmtui

super + p
    mpv $(xclip -o)

super + x
    slock


control + {equal,minus}
    xbacklight -{inc,dec} 2

XF86MonBrightness{Up,Down}
    xbacklight -{inc,dec} 2

XF86Audio{Raise,Lower}Volume
    $HOME/script/volume.sh {up, down}

XF86AudioMute
    $HOME/script/volume.sh toggle

XF86Calculator
    xcalc
