super + Return
    $TERMINAL

super + v
    $TERMINAL -e $EDITOR

super + d
    dmenu_run

super + w
    $BROWSER

super + {equal, minus, BackSpace, plus}
    $HOME/.local/bin/volume.sh {up, down, toggle, togglemic}

super + shift + BackSpace
    $HOME/.local/bin/exit.sh

super + m
    $HOME/.local/bin/mount.sh

super + f
    $TERMINAL -e nnn -Rr

Print
    $HOME/.local/bin/screenshot

super + x
    slock

super + n
    $TERMINAL -e ncmpcpp

super + N
    $TERMINAL -e nmtui

super + t
    $TERMINAL -e btop


control + {equal,minus}
    xbacklight -{inc,dec} 2

XF86MonBrightness{Up,Down}
    xbacklight -{inc,dec} 2

XF86Audio{Raise,Lower}Volume
    $HOME/.local/bin/volume.sh {up, down}

XF86AudioMute
    $HOME/.local/bin/volume.sh toggle

XF86Calculator
    xcalc

