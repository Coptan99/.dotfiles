alt + Return
    $TERMINAL

alt + w
    $BROWSER

XF86MonBrightnessUp
    brillo -A 2

XF86MonBrightnessDown
    brillo -U 2

XF86Audio{Raise,Lower}Volume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%{+,-}; kill -44 $(pidof dwmblocks)

XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle; kill -44 $(pidof dwmblocks)

XF86Calculator
    xcalc

Print
    $HOME/.local/bin/screenshot

alt + Print
    $HOME/.local/bin/screenshot copyfull

shift + Print
    $HOME/.local/bin/screenshot copy

alt + shift + Print
    $HOME/.local/bin/screenshot window

alt + m
    $HOME/.local/bin/mount.sh

alt + shift + BackSpace
    $HOME/.local/bin/powermenu

alt + r
    st -e lf

alt + t
    st -e gotop
